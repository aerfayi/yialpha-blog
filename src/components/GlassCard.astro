---
interface Props {
  title?: string;
  color?: "cyan" | "violet";
  class?: string;
}

const { title, color = "cyan", class: className = "" } = Astro.props;

const borderColor =
  color === "violet"
    ? "border-violet-400/10 hover:border-violet-400/20"
    : "border-cyan-400/10 hover:border-cyan-400/20";

const glowColor = color === "violet" ? "bg-violet-400/10" : "bg-cyan-400/10";
---

<div
  class={`
    group relative overflow-hidden

    rounded-3xl
    border
    bg-white/[0.03]

    p-8
    backdrop-blur-xl

    transition duration-500

    hover:-translate-y-1
    hover:bg-white/[0.05]

    ${borderColor}
    ${className}
  `}
>
  <!-- hover glow -->
  <div
    class="pointer-events-none
      absolute inset-0
      opacity-0
      transition duration-700
      group-hover:opacity-100"
  >
    <div
      class={`
        absolute -top-24 left-1/2
        h-48 w-48
        -translate-x-1/2

        rounded-full
        blur-3xl

        ${glowColor}
      `}
    >
    </div>
  </div>

  <!-- 边缘高光 -->
  <div
    class="absolute inset-0
      rounded-3xl
      bg-gradient-to-b
      from-white/[0.08]
      to-transparent
      opacity-40
      pointer-events-none"
  >
  </div>

  <!-- 内容 -->
  <div class="relative z-10">
    {title && <h2 class="mb-6 text-2xl font-bold">{title}</h2>}

    <slot />
  </div>
</div>
