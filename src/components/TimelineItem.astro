---
interface Props {
  year: string;
  title: string;
  description: string;
}

const { year, title, description } = Astro.props;
---

<div class="relative pl-10">
  <!-- 线 -->
  <div class="absolute left-[11px]
    top-0 h-full w-px
    bg-white/10"></div>

  <!-- 点 -->
  <div
    class="absolute left-0 top-2
    h-6 w-6 rounded-full
    border border-cyan-400/30
    bg-cyan-400/10
    backdrop-blur-xl"
  >
  </div>

  <div class="pb-14">
    <p class="mb-3 text-sm
      tracking-[0.2em]
      text-cyan-300/60">
      {year}
    </p>

    <h3 class="mb-4 text-2xl
      font-bold text-zinc-100">
      {title}
    </h3>

    <p class="max-w-2xl
      leading-8
      text-zinc-400">
      {description}
    </p>
  </div>
</div>
