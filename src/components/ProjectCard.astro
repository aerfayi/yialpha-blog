---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  link?: string;
}

const { title, description, tags = [], link = "#" } = Astro.props;
---

<a
  href={link}
  target="_blank"
  class="group block
  rounded-3xl
  border border-white/5
  bg-white/[0.03]
  p-8 backdrop-blur-xl
  transition duration-300
  hover:-translate-y-1
  hover:border-cyan-400/20
  hover:bg-white/[0.05]"
>
  <!-- 标题 -->
  <h2
    class="mb-4 text-3xl
    font-bold tracking-tight
    transition
    group-hover:text-cyan-300"
  >
    {title}
  </h2>

  <!-- 描述 -->
  <p class="mb-8
    leading-8
    text-zinc-400">
    {description}
  </p>

  <!-- 标签 -->
  <div class="flex flex-wrap gap-3">
    {
      tags.map((tag) => (
        <span
          class="rounded-full
          border border-white/10
          bg-white/[0.03]

          px-4 py-2
          text-sm text-zinc-300"
        >
          {tag}
        </span>
      ))
    }
  </div>
</a>
